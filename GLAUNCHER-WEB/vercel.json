{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb" }
        }
    ],
    "routes": [
        {
            "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|svg|mp3|woff|woff2|ttf))",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ]
}