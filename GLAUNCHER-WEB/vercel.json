{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb" }
        }
    ],
    "routes": [
        {
            "src": "/css/(.*)", "dest": "/css/$1"
        },
        {
            "src": "/js/(.*)", "dest": "/js/$1"
        },
        {
            "src": "/images/(.*)", "dest": "/images/$1"
        },
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ]
}